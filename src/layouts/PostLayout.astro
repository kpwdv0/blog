---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';

interface Props {
  title: string;
  category: string;
  date: Date;
  readTime: number;
  katex?: boolean;
  thumbnail?: string;
}

const { title, category, date, readTime, katex = false, thumbnail } = Astro.props;
const needsKatex = katex || ['math', 'cs'].includes(category);
---

<div id="progress-bar" style="position:fixed;top:0;left:0;width:0%;height:2px;background:var(--text);z-index:9998;pointer-events:none;"></div>

<BaseLayout title={title}>
  <Fragment slot="head">
    {needsKatex && (
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous" />
    )}
  </Fragment>

  <div class="container py-0">
    <div class="row justify-content-center">
      <div class="col-12">

        <div class="post-header">
          <h1>{title}</h1>
          <PostMeta date={date} readTime={readTime} />
        </div>

        <article class="prose">
          <slot />
        </article>

        <hr style="border-color:var(--border);margin:3rem 0 1.5rem;" />

        <div class="mb-5">
          <script src="https://giscus.app/client.js"
                  data-repo="kpwdv0/blog"
                  data-repo-id="R_kgDOQAwPjQ"
                  data-category="Announcements"
                  data-category-id="DIC_kwDOQAwPjc4C36tX"
                  data-mapping="pathname"
                  data-strict="0"
                  data-reactions-enabled="1"
                  data-emit-metadata="0"
                  data-input-position="top"
                  data-theme="https://kpwdv0.github.io/blog/styles/giscus-theme.css"
                  data-lang="en"
                  crossorigin="anonymous"
                  async>
          </script>
        </div>

        <a id="back-btn" href="/writing" style="font-size:0.85rem;color:var(--text-muted);">← Back</a>
        <div class="pb-5"></div>

        <script>
          const btn = document.getElementById('back-btn');
          const ref = document.referrer;
          if (ref && new URL(ref).origin === location.origin) {
            btn.addEventListener('click', (e) => { e.preventDefault(); history.back(); });
          }

          const bar = document.getElementById('progress-bar')!;
          const doc = document.documentElement;
          let maxScroll = doc.scrollHeight - doc.clientHeight;
          window.addEventListener('resize', () => { maxScroll = doc.scrollHeight - doc.clientHeight; }, { passive: true });
          window.addEventListener('scroll', () => {
            bar.style.width = Math.min(doc.scrollTop / maxScroll * 100, 100) + '%';
          }, { passive: true });
        </script>

      </div>
    </div>
  </div>
</BaseLayout>

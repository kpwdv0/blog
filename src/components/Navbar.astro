---
const navLinks = [
  { href: '/writing', label: 'Writing' },
  { href: '/category/math', label: 'Math' },
  { href: '/category/cs', label: 'CS' },
  { href: '/category/essays', label: 'Essays' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar navbar-expand-md blog-navbar sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/">kira w.</a>

    <button
      class="navbar-toggler border-0"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNav"
      aria-controls="mainNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
      style="box-shadow:none;"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav ms-auto gap-1">
        {navLinks.map(({ href, label }) => (
          <li class="nav-item">
            <a
              class:list={['nav-link', { active: currentPath.startsWith(href) }]}
              href={href}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

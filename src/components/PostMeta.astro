---
interface Props {
  date: Date;
  readTime: number;
}

const { date, readTime } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="post-meta mt-2">
  <time datetime={new Date(date).toISOString().slice(0, 10)}>{formatted}</time>
  <span class="separator">·</span>
  <span>{readTime} min read</span>
</div>

---
const { frontmatter } = Astro.props;
const { title, date } = frontmatter || {};

function fmt(d) {
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/contrib/auto-render.min.js"
        onload="renderMathInElement(document.body);"></script>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title ?? "untitled"} — kira w.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/theme.css" />
  </head>

  <body>

    <nav class="navbar navbar-expand-sm sticky-top border-bottom">
      <div class="container" style="max-width:720px">
        <a class="navbar-brand" href="/">kira w.</a>
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMenu"
                aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto gap-sm-2">
            <li class="nav-item"><a class="nav-link text-secondary" href="/posts">writing</a></li>
            <li class="nav-item"><a class="nav-link text-secondary" href="/#contact">contact</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container py-0" style="max-width:720px">

      <!-- Post header -->
      <div class="py-5 border-bottom">
        <a href="/posts" class="text-secondary d-inline-block mb-3"
           style="font-size:.82rem; text-decoration:none">← all posts</a>
        <h1 class="fst-italic fw-normal mb-3" style="font-size:2.4rem; line-height:1.2">
          {title ?? "untitled"}
        </h1>
        {date && (
          <small class="text-secondary text-uppercase" style="font-size:.7rem; letter-spacing:.1em">
            {fmt(date)}
          </small>
        )}
      </div>

      <!-- Article body -->
      <article class="prose py-5 border-bottom">
        <slot />
      </article>

      <!-- Comments -->
      <div class="py-5">
        <script src="https://giscus.app/client.js"
                data-repo="kikiw314/blog"
                data-repo-id="R_kgDOQAwPjQ"
                data-category="Announcements"
                data-category-id="DIC_kwDOQAwPjc4C36tX"
                data-mapping="pathname"
                data-strict="0"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="top"
                data-theme="light"
                data-lang="en"
                crossorigin="anonymous"
                async>
        </script>
      </div>

      <!-- Footer -->
      <div class="d-flex justify-content-between align-items-center py-4">
        <a href="/posts" class="text-secondary" style="font-size:.85rem; text-decoration:none">← all posts</a>
        <span class="text-secondary" style="font-size:.78rem; font-weight:300">made with ♡ by kira</span>
      </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

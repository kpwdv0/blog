---
const allPosts = await Astro.glob('./*.md');

function toMs(d) {
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).getTime();
}
function fmt(d) {
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric'
  });
}

const posts = allPosts
  .filter(p => p.frontmatter.date)
  .sort((a, b) => toMs(b.frontmatter.date) - toMs(a.frontmatter.date));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>writing — kira w.</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/theme.css">
</head>
<body>

  <nav class="navbar navbar-expand-sm sticky-top border-bottom">
    <div class="container" style="max-width:720px">
      <a class="navbar-brand" href="/">kira w.</a>
      <button class="navbar-toggler border-0" type="button"
              data-bs-toggle="collapse" data-bs-target="#navMenu"
              aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto gap-sm-2">
          <li class="nav-item"><a class="nav-link text-secondary" href="/posts">writing</a></li>
          <li class="nav-item"><a class="nav-link text-secondary" href="/#contact">contact</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-0" style="max-width:720px">

    <div class="py-5 border-bottom mb-2">
      <h1 class="fst-italic fw-normal mb-0">writing</h1>
    </div>

    <ul class="list-unstyled mb-0">
      {posts.map(post => (
        <li class="py-3 border-bottom">
          <small class="d-block text-secondary text-uppercase mb-1"
                 style="font-size:.7rem; letter-spacing:.1em">
            {fmt(post.frontmatter.date)}
          </small>
          <a class="post-link" href={post.url}>{post.frontmatter.title}</a>
        </li>
      ))}
    </ul>

    <footer class="text-center text-secondary border-top py-4 mt-3" style="font-size:.78rem; font-weight:300">
      made with ♡ by kira
    </footer>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
